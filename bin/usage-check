#!/usr/bin/env bash
set -euo pipefail

SELF="$0"
[ -L "$SELF" ] && SELF=$(readlink -f "$SELF")
SCRIPT_DIR=$(cd -- "$(dirname -- "$SELF")" && pwd)
# shellcheck source=_common.sh
source "$SCRIPT_DIR/_common.sh"
load_env

usage() {
  echo "Usage: $(basename "$0") [claude|codex|copilot] [--json] [--debug]"
  exit 1
}

service="all"
format="text"
debug_mode=false
for arg in "$@"; do
  case "$arg" in
    claude|codex|copilot) service="$arg" ;;
    --json) format="json" ;;
    --debug) debug_mode=true ;;
    *) usage ;;
  esac
done

case "$service" in
  all) fetch_services="claude,codex,copilot" ;;
  *) fetch_services="$service" ;;
esac

if ! extension_fetch "$fetch_services" 30; then
  [ "$debug_mode" = true ] && debug_dump
  echo "Fetch failed" >&2
  exit 1
fi

[ "$debug_mode" = true ] && debug_dump

RENDERER_JS="$ROOT_DIR/dist/cli/render.js"
if [ ! -f "$RENDERER_JS" ]; then
  echo "Missing renderer: $RENDERER_JS" >&2
  echo "Action: run 'npm install' and 'npm run build' in $ROOT_DIR" >&2
  exit 1
fi

render_args=()
[ "$service" != "all" ] && render_args+=("$service")
[ "$format" = "json" ] && render_args+=("--json")

if [ "${#render_args[@]}" -gt 0 ]; then
  CACHE_DIR="$CACHE_DIR" node "$RENDERER_JS" "${render_args[@]}"
else
  CACHE_DIR="$CACHE_DIR" node "$RENDERER_JS"
fi
